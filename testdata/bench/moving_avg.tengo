fmt := import("fmt")

n := 200000
window := 10

data := []
for i := 0; i < n; i++ {
	data = append(data, (i * 13) % 1000)
}

sum := 0
for i := 0; i < window; i++ {
	sum += data[i]
}

out := 0
for i := window; i < n; i++ {
	sum += data[i]
	sum -= data[i-window]
	out += sum / window
}

fmt.println(out)
