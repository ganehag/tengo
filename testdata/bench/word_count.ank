strings = import("strings")

text = ""
n = 20000

for i = 0; i < n; i++ {
    text += "lorem ipsum dolor sit amet consectetur adipiscing elit "
}

words = strings.Split(text, " ")
counts = {}

for w in words {
    if w == "" {
        continue
    }
    if counts[w] == nil {
        counts[w] = 1
    } else {
        counts[w] += 1
    }
}

out = 0
for k in counts {
    out += counts[k]
}

println(out)
