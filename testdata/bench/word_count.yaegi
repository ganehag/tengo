package main

import (
	"fmt"
	"strings"
)

func main() {
	text := ""
	n := 20000

	for i := 0; i < n; i++ {
		text += "lorem ipsum dolor sit amet consectetur adipiscing elit "
	}

	words := strings.Split(text, " ")
	counts := make(map[string]int)

	for _, w := range words {
		if w == "" {
			continue
		}
		counts[w]++
	}

	out := 0
	for _, v := range counts {
		out += v
	}

	fmt.Println(out)
}
