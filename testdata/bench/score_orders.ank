score = func(order) {
    total = order.total
    items = order.items
    country = order.country
    priority = order.priority

    s = 0

    if total > 1000 {
        s += 50
    } else if total > 250 {
        s += 20
    } else {
        s += 5
    }

    if items > 10 {
        s += items * 2
    } else {
        s += items
    }

    if country == "SE" {
        s += 7
    } else if country == "US" {
        s += 5
    } else {
        s += 3
    }

    if priority {
        s *= 2
    }

    return s
}

orders = []
n = 100000

for i = 0; i < n; i++ {
    country = "DE"
    if i % 3 == 0 {
        country = "SE"
    } else if i % 3 == 1 {
        country = "US"
    }
    orders += {
        "total": (i * 37) % 1500,
        "items": (i % 17) + 1,
        "country": country,
        "priority": i % 11 == 0
    }
}

out = 0
for order in orders {
    out += score(order)
}

println(out)
