fmt := import("fmt")

records := []
n := 100000

for i := 0; i < n; i++ {
	records = append(records, {
		"id": i,
		"value": (i * 19) % 500,
		"active": i % 3 == 0
	})
}

result := []

for r in records {
	if !r["active"] {
		continue
	}
	if r["value"] > 100 {
		result = append(result, {
			"id": r["id"],
			"score": r["value"] * 2
		})
	}
}

out := len(result)
fmt.println(out)

